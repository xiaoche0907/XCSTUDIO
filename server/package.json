{
  "name": "xc-studio-server",
  "version": "1.0.0",
  "description": "XC-STUDIO Alibaba Cloud FC Backend",
  "main": "dist/bundle.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --outfile=dist/bundle.js --format=cjs --external:@prisma/client",
    "start": "node dist/bundle.js"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@prisma/client": "^6.2.1",
    "@vendia/serverless-express": "^4.12.6",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "esbuild": "^0.27.4",
    "prisma": "^6.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
