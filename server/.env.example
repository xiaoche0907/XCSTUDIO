# XC-STUDIO 后端环境变量模板
# 请在阿里云函数计算 (FC) 环境变量或本地 .env 文件中设置

PORT=9000
NODE_ENV=development

# Comma-separated allowed origins for browser requests
# Example: https://xcwork-tool.online,https://www.xcwork-tool.online
CORS_ORIGINS=

# --- API 密钥 (从云雾/柏拉图获取) ---
# Multiple keys supported, comma-separated
YUNWU_API_KEYS=your_yunwu_key_here
PLATO_API_KEYS=your_plato_key_here
GEMINI_API_KEY=your_direct_gemini_key_here

# --- 数据库 (阿里云 RDS PostgreSQL) ---
DATABASE_URL="postgresql://user:password@hostname:port/dbname?schema=public"

# --- Admin ---
ADMIN_TOKEN=change_me_long_random

# --- 登录与鉴权 (推荐 Clerk) ---
CLERK_SECRET_KEY=your_clerk_secret_key
# 如果使用阿里云 IDaaS 或其他 JWT 方式，请调整此处
JWT_SECRET=your_jwt_secret_for_fallback

# Access token TTL (e.g. 15m, 1h, 7d)
ACCESS_TOKEN_TTL=7d

# Optional: allow password bootstrap for existing users without passwordHash
ALLOW_PASSWORD_BOOTSTRAP=false

# Optional: control signup
ALLOW_SIGNUP=true

# Admin emails (comma-separated). These accounts will be treated as ADMIN.
ADMIN_EMAILS=
