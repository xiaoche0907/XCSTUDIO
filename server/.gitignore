# keep only HTML entrypoints under version control.
public/xc-video/*
!public/xc-video/index.html

# Serverless deployment state
.s/
*.cache

# Deploy logs / diagnostics
deploy_*.log
deploy_*.txt
deploy_*.yaml
full_info.log
